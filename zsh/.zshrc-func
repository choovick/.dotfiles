# helper function to select ssh connection from .ssh/config
sssh() {
  # Extract hosts from ~/.ssh/config
  local selected_host
  selected_host=$(grep -E "^Host " ~/.ssh/config | awk '{print $2}' | fzf --prompt="Select SSH Host: " --preview="echo Connecting to {}")

  # If a host is selected, connect to it
  if [[ -n "$selected_host" ]]; then
    echo "Connecting to $selected_host..."
    ssh "$selected_host"
  else
    echo "No host selected."
  fi
}

# helper function to split folders in tmux panes
function split-folders() {
  local counter=0
  # Use fzf to select multiple folders
  local folders
  #folders=$(ls -d */ | fzf --multi --preview 'ls -la {}')
  # all subfolders, obey git!
  folders=$(tree -dfi --noreport -I "$(git check-ignore $(find . -type d))" | awk '{print $1}' | fzf --multi --preview 'ls -la {}')

  echo "Selected folders: $folders"

  if [[ -z "$folders" ]]; then
    echo "No folders selected. Exiting."
    return 1
  fi

  # Iterate over selected folders (handle newline-separated values)
  while IFS= read -r folder; do
    if ((counter % 4 == 0)); then
      tmux split-window -v "cd $folder && exec $SHELL"
    else
      tmux split-window -h "cd $folder && exec $SHELL"
    fi
    tmux select-layout tiled
    counter=$((counter + 1))
  done <<<"$folders"

  echo "Will exit in 5 seconds, press any key to cancel"
  if read -s -k 1 -t 5; then
    return
  else
    exit
  fi
}

# this will search dev folders with some ingnores
fcd() {
  local folder="$1" # Get the folder name from the first argument
  local selected_dir
  # is second argument is provided, set no_ignore variable to --no-ignore
  [[ -n "$2" ]] && local no_ignore="--no-ignore" || local no_ignore=""
  selected_dir=$(fd --type d $no_ignore --maxdepth 15 \
    -E '.vscode*' \
    -E '.idea*' \
    -E 'Library/*' \
    -E '_arch/*' \
    -E '.local/*' \
    -E 'node_modules/*' \
    -E 'bower_components/*' \
    -E 'public/*' \
    -E 'dist/*' \
    -E 'build/*' \
    -E 'target/*' \
    --hidden --strip-cwd-prefix --exclude .git \
    --base-directory $folder | fzf +m --height 40%)
  cd "$folder/$selected_dir" || return
}
##  Bind Ctrl+g to the fcd function with a folder of /dev/infrastructure
bindkey -s '^g' 'fcd $HOME no-ignore\n'
##  Bind Ctrl+f to the fcd function with a folder of "dev"
bindkey -s '^f' 'fcd $HOME/dev\n'

# helper function to select aws profile / region / ec2 instance and connect via ssm
ssm() {
  local profile="" region="" target=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -p|--profile)     profile="$2"; shift 2 ;;
      -r|--region)      region="$2"; shift 2 ;;
      -i|--instance-id) target="$2"; shift 2 ;;
      *) echo "Usage: ssm [-p profile] [-r region] [-i instance-id]" >&2; return 1 ;;
    esac
  done

  # Profile: use given, else fall back to current AWS_PROFILE, else fzf-pick
  if [[ -z "$profile" && -n "$AWS_PROFILE" ]]; then
    profile="$AWS_PROFILE"
    echo "Using cached profile '$profile' (unset AWS_PROFILE, or pass -p, to change)" >&2
  fi
  if [[ -z "$profile" ]]; then
    profile=$(aws configure list-profiles | fzf --prompt="AWS Profile> ")
    [[ -z "$profile" ]] && { echo "No profile selected" >&2; return 1; }
  fi
  export AWS_PROFILE="$profile"

  # Region: use given, else fall back to current default, else fzf-pick
  if [[ -z "$region" && -n "${AWS_REGION:-$AWS_DEFAULT_REGION}" ]]; then
    region="${AWS_REGION:-$AWS_DEFAULT_REGION}"
    echo "Using cached region '$region' (unset AWS_REGION AWS_DEFAULT_REGION, or pass -r, to change)" >&2
  fi
  if [[ -z "$region" ]]; then
    region=$(aws ec2 describe-regions --query 'Regions[].RegionName' --output text |
      tr '\t' '\n' | sort | fzf --prompt="AWS Region ($profile)> ")
    [[ -z "$region" ]] && { echo "No region selected" >&2; return 1; }
  fi
  export AWS_REGION="$region"
  export AWS_DEFAULT_REGION="$region"

  # Instance: use given id, else describe + fzf-filter by name
  if [[ -z "$target" ]]; then
    local selection tmpfile pid spin='/-\|' i=0
    tmpfile=$(mktemp)
    aws ec2 describe-instances \
      --filters "Name=instance-state-name,Values=running,stopped,pending,stopping" \
      --query 'Reservations[].Instances[].[Tags[?Key==`Name`]|[0].Value, InstanceId, State.Name, InstanceType, PrivateIpAddress]' \
      --output text >"$tmpfile" 2>&1 &
    pid=$!
    while kill -0 "$pid" 2>/dev/null; do
      printf "\r%s Fetching instances in %s..." "${spin:$((i % ${#spin})):1}" "$region" >&2
      i=$((i + 1))
      sleep 0.1
    done
    wait "$pid"
    printf "\r\033[K" >&2
    selection=$(sort -u "$tmpfile" | fzf --prompt="EC2 Instance ($region)> " \
      --header="NAME  INSTANCE-ID  STATE  TYPE  PRIVATE-IP")
    rm -f "$tmpfile"
    [[ -z "$selection" ]] && { echo "No instance selected" >&2; return 1; }
    target=$(awk '{print $2}' <<<"$selection")
  fi

  echo "Connecting to $target via SSM (profile=$profile region=$region)..."
  aws ssm start-session --target "$target"
}

# clear tmux history and screen
c() {
  clear
  tmux clear-history
}

# Yazi
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

# TMUX auto-start for interactive terminal apps.
# Scope this logic to terminal emulators we use for tmux sessions.
if [[ "$TERM_PROGRAM" = "iTerm.app" || "$TERM_PROGRAM" = "WezTerm" || "$TERM_PROGRAM" = "ghostty" ]]; then
  # Skip when we are already inside tmux.
  if [ "$TMUX" = "" ]; then
    # Avoid nested tmux from Neovim terminal buffers.
    if [ -n "$NVIM_LISTEN_ADDRESS" ]; then
      echo "We are in nvim terminal"
    else
      # Session routing:
      # - Ghostty quick terminal: session "quick"
      # - Normal terminals: session "main"
      tmux_session="main"
      is_quick_terminal="0"
      if [[ -n "$GHOSTTY_QUICK_TERMINAL" ]]; then
        tmux_session="quick"
        is_quick_terminal="1"
      fi
      tmux attach-session -t "$tmux_session"

      # If attach fails, create the target session.
      if [ $? -ne 0 ]; then
        # Create detached session first so it can be initialized before attach.
        tmux new-session -s "$tmux_session" -d
        # Only provision the standard window layout in non-quick mode.
        # Quick terminal should use the existing session layout as-is.
        if [[ "$is_quick_terminal" = "0" ]]; then
          #tmux kill-window -t "${tmux_session}:1"
          tmux new-window -d -t "${tmux_session}:2" -n "sec" -c "$HOME"
          tmux new-window -d -t "${tmux_session}:3" -n "third" -c "$HOME"
          tmux new-window -d -t "${tmux_session}:4" -n "dev" -c "$HOME/dev"
          tmux new-window -d -t "${tmux_session}:5" -n "infra" -c "$HOME/dev/infrastructure"
          tmux new-window -d -t "${tmux_session}:6" -n "temp" -c "$HOME/temp"
          tmux new-window -d -t "${tmux_session}:7" -n "Downloads" -c "$HOME/Downloads"
          tmux new-window -d -t "${tmux_session}:8" -n ".dotfiles" -c "$HOME/.dotfiles"
          tmux new-window -d -t "${tmux_session}:9" -n "last" -c "$HOME"
        else
           tmux new-window -d -t "${tmux_session}:2" -n "notes" -c "$HOME/dev/notes"
        fi
        # Attach after create/init.
        tmux attach-session -t "$tmux_session"
      fi
    fi
  fi
fi
